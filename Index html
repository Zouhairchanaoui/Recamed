    <script>
        // --- إدارة البيانات ---
        let regions = JSON.parse(localStorage.getItem('regions')) || [];
        let shops = JSON.parse(localStorage.getItem('shops')) || [];
        
        let currentRegionId = null;
        let deleteFlowRegionId = null;

        function saveData() {
            localStorage.setItem('regions', JSON.stringify(regions));
            localStorage.setItem('shops', JSON.stringify(shops));
        }

        function generateId() {
            return Date.now().toString(36) + Math.random().toString(36).substr(2);
        }

        function isArabic(text) {
            const arabicPattern = /[\u0600-\u06FF\u0750-\u077F]/;
            return arabicPattern.test(text);
        }

        function handleInteractionEvents(element, onClick, onLongPress) {
            let pressTimer;
            let isLongPress = false;

            const start = (e) => {
                if (e.type === 'mousedown' && e.button !== 0) return; 
                isLongPress = false;
                pressTimer = setTimeout(() => {
                    isLongPress = true;
                    if(onLongPress) onLongPress(e);
                }, 600);
            };

            const cancel = () => { clearTimeout(pressTimer); };

            const end = (e) => {
                clearTimeout(pressTimer);
                if (!isLongPress && onClick) {
                    onClick(e);
                }
            };

            element.addEventListener('touchstart', start, {passive: true});
            element.addEventListener('touchend', end);
            element.addEventListener('mousedown', start);
            element.addEventListener('mouseup', end);
            element.addEventListener('mouseleave', cancel);
            element.addEventListener('touchmove', cancel, {passive: true});
            element.addEventListener('contextmenu', (e) => { 
                e.preventDefault(); 
            });
        }

        // --- واجهة المستخدم والتنقل ---
        
        function switchScreen(screenId) {
            document.querySelectorAll('.search-bar-container').forEach(el => el.classList.remove('show'));
            document.querySelectorAll('[id$="-search-icon"]').forEach(el => el.classList.remove('hidden'));
            document.querySelectorAll('[id$="-close-icon"]').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.search-input').forEach(el => el.value = '');
            document.querySelectorAll('.content').forEach(el => el.classList.remove('with-search'));

            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(screenId).classList.add('active');
        }

        function goBack(targetScreen) {
            switchScreen(targetScreen);
            if(targetScreen === 'main-screen') renderRegions();
            if(targetScreen === 'delete-shops-select-screen') renderDeleteShopsSelect();
        }

        function toggleSearch(prefix, contentId) {
            const container = document.getElementById(`${prefix}-search-container`);
            const searchIcon = document.getElementById(`${prefix}-search-icon`);
            const closeIcon = document.getElementById(`${prefix}-close-icon`);
            const input = document.getElementById(`${prefix}-search-input`);
            const contentDiv = document.getElementById(contentId);

            if (container.classList.contains('show')) {
                container.classList.remove('show');
                searchIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
                input.value = ''; 
                if(contentDiv) contentDiv.classList.remove('with-search');
                
                if(prefix === 'main') renderRegions();
                if(prefix === 'region') renderShops();
                if(prefix === 'del-reg') renderDeleteRegions();
                if(prefix === 'del-shop-sel') renderDeleteShopsSelect();
                if(prefix === 'del-shop-list') renderDeleteShopsList();
            } else {
                container.classList.add('show');
                searchIcon.classList.add('hidden');
                closeIcon.classList.remove('hidden');
                if(contentDiv) contentDiv.classList.add('with-search'); 
                input.focus();
            }
        }

        document.getElementById('main-search-input').addEventListener('input', (e) => renderRegions(e.target.value));
        document.getElementById('region-search-input').addEventListener('input', (e) => renderShops(e.target.value));
        document.getElementById('del-reg-search-input').addEventListener('input', (e) => renderDeleteRegions(e.target.value));
        document.getElementById('del-shop-sel-search-input').addEventListener('input', (e) => renderDeleteShopsSelect(e.target.value));
        document.getElementById('del-shop-list-search-input').addEventListener('input', (e) => renderDeleteShopsList(e.target.value));

        function toggleDeleteDropdown(event) {
            event.stopPropagation();
            const dropdown = document.getElementById('delete-dropdown');
            dropdown.classList.toggle('show');
        }

        document.addEventListener('click', (e) => {
            const dropdown = document.getElementById('delete-dropdown');
            if (dropdown && dropdown.classList.contains('show') && !e.target.closest('.header-side')) {
                dropdown.classList.remove('show');
            }

            // إغلاق القائمة المنسدلة المخصصة للمناطق عند النقر خارجها
            if (!e.target.closest('.custom-select-wrapper')) {
                const regionDropdown = document.getElementById('custom-region-dropdown');
                const regionWrapper = document.getElementById('custom-region-wrapper');
                if(regionDropdown) {
                    regionDropdown.classList.remove('show');
                    regionWrapper.classList.remove('active');
                }
            }
        });

        function openBottomSheet(screenType) {
            document.getElementById('bottom-sheet-overlay').classList.add('show');
            document.getElementById('bottom-sheet').classList.add('show');
            
            if (screenType === 'main') {
                document.getElementById('main-sheet-options').classList.remove('hidden');
                document.getElementById('region-sheet-options').classList.add('hidden');
            } else {
                document.getElementById('main-sheet-options').classList.add('hidden');
                document.getElementById('region-sheet-options').classList.remove('hidden');
            }
        }

        function closeBottomSheet() {
            document.getElementById('bottom-sheet-overlay').classList.remove('show');
            document.getElementById('bottom-sheet').classList.remove('show');
        }

        function openModal(id) { document.getElementById(id).classList.add('show'); }
        function closeModal(id) {
            document.getElementById(id).classList.remove('show');
            const inputs = document.getElementById(id).querySelectorAll('input[type="text"], input[type="url"]');
            inputs.forEach(input => input.value = '');
            
            // إعادة ضبط القائمة المنسدلة المخصصة إذا كنا نغلق نافذة إضافة صيدلية
            if(id === 'add-shop-modal') {
                document.getElementById('custom-region-dropdown').classList.remove('show');
                document.getElementById('custom-region-wrapper').classList.remove('active');
            }
        }

        // --- رسالة التنبيه المخصصة ---
        function showCustomAlert(title, message, isSuccess = true) {
            const modalTitle = document.getElementById('custom-alert-title');
            const iconContainer = document.getElementById('alert-icon-container');
            
            modalTitle.textContent = title;
            modalTitle.style.color = isSuccess ? 'var(--success-color)' : 'var(--danger-color)';
            document.getElementById('custom-alert-message').textContent = message;

            if (isSuccess) {
                iconContainer.innerHTML = `<svg style="width: 50px; height: 50px; fill: var(--success-color);" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>`;
            } else {
                iconContainer.innerHTML = `<svg style="width: 50px; height: 50px; fill: var(--danger-color);" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>`;
            }

            openModal('custom-alert-modal');
        }

        // --- عرض البيانات (الريندر) ---

        const emptyIcon = `<svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14z"/><path d="M7 12h10v2H7z"/></svg>`;

        function renderRegions(searchQuery = '') {
            const container = document.getElementById('regions-list');
            container.innerHTML = '';
            let filtered = regions.filter(r => r.name.toLowerCase().includes(searchQuery.toLowerCase()));

            if (filtered.length === 0) {
                container.innerHTML = `<div class="empty-state">${emptyIcon}لا توجد مناطق.</div>`;
                return;
            }

            filtered.forEach(region => {
                const isAr = isArabic(region.name);
                const card = document.createElement('div');
                card.className = 'card';
                
                card.innerHTML = `
                    <div class="card-inner ${isAr ? '' : 'ltr-layout'}">
                        <div class="card-title ${isAr ? 'rtl-text' : 'ltr-text'}">${region.name}</div>
                    </div>
                `;

                handleInteractionEvents(card, 
                    () => {
                        currentRegionId = region.id;
                        document.getElementById('current-region-title').textContent = region.name;
                        switchScreen('region-screen');
                        renderShops();
                    },
                    () => {
                        document.getElementById('edit-region-id').value = region.id;
                        document.getElementById('edit-region-name').value = region.name;
                        openModal('edit-region-modal');
                    }
                );

                container.appendChild(card);
            });
        }

        function renderShops(searchQuery = '') {
            const container = document.getElementById('shops-list');
            container.innerHTML = '';
            let filtered = shops.filter(s => s.regionId === currentRegionId);
            if (searchQuery) filtered = filtered.filter(s => s.name.toLowerCase().includes(searchQuery.toLowerCase()));

            filtered.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));

            if (filtered.length === 0) {
                container.innerHTML = `<div class="empty-state">${emptyIcon}لا توجد صيدليات في هذه المنطقة.</div>`;
                return;
            }

            filtered.forEach(shop => {
                const isAr = isArabic(shop.name);
                const card = document.createElement('div');
                card.className = 'card';
                
                card.innerHTML = `
                    <div class="card-inner ${isAr ? '' : 'ltr-layout'}">
                        <div class="card-title ${isAr ? 'rtl-text' : 'ltr-text'}">${shop.name}</div>
                    </div>
                `;

                handleInteractionEvents(card,
                    () => {
                        if(shop.link) {
                            let url = shop.link.trim();
                            if (!/^https?:\/\//i.test(url)) url = 'http://' + url;
                            window.open(url, '_blank');
                        } else {
                            showCustomAlert("عذراً", "لا يوجد رابط مضاف لهذه الصيدلية", false);
                        }
                    },
                    () => {
                        document.getElementById('edit-shop-id').value = shop.id;
                        document.getElementById('edit-shop-name').value = shop.name;
                        document.getElementById('edit-shop-link').value = shop.link || '';
                        openModal('edit-shop-modal');
                    }
                );

                container.appendChild(card);
            });
        }

        function openDeleteRegionsScreen() {
            document.getElementById('delete-dropdown').classList.remove('show');
            switchScreen('delete-regions-screen');
            renderDeleteRegions();
        }

        function renderDeleteRegions(searchQuery = '') {
            const container = document.getElementById('delete-regions-list');
            container.innerHTML = '';
            let filtered = regions.filter(r => r.name.toLowerCase().includes(searchQuery.toLowerCase()));

            if (filtered.length === 0) {
                container.innerHTML = `<div class="empty-state">${emptyIcon}لا توجد مناطق للحذف.</div>`;
                return;
            }

            filtered.forEach(region => {
                const isAr = isArabic(region.name);
                const card = document.createElement('div');
                card.className = 'card';
                card.style.cursor = 'default';
                card.innerHTML = `
                    <div class="card-inner ${isAr ? '' : 'ltr-layout'}">
                        <div class="card-title ${isAr ? 'rtl-text' : 'ltr-text'}">${region.name}</div>
                        <div class="card-action-btn" onclick="requestDelete('${region.id}', 'region')">
                            <svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        function openDeleteShopsSelectScreen() {
            document.getElementById('delete-dropdown').classList.remove('show');
            switchScreen('delete-shops-select-screen');
            renderDeleteShopsSelect();
        }

        function renderDeleteShopsSelect(searchQuery = '') {
            const container = document.getElementById('delete-shops-select-list');
            container.innerHTML = '';
            let filtered = regions.filter(r => r.name.toLowerCase().includes(searchQuery.toLowerCase()));

            if (filtered.length === 0) {
                container.innerHTML = `<div class="empty-state">${emptyIcon}لا توجد مناطق.</div>`;
                return;
            }

            filtered.forEach(region => {
                const isAr = isArabic(region.name);
                const card = document.createElement('div');
                card.className = 'card';
                card.innerHTML = `
                    <div class="card-inner ${isAr ? '' : 'ltr-layout'}">
                        <div class="card-title ${isAr ? 'rtl-text' : 'ltr-text'}">${region.name}</div>
                    </div>
                `;
                card.addEventListener('click', () => {
                    deleteFlowRegionId = region.id;
                    document.getElementById('del-shop-list-title').textContent = region.name;
                    switchScreen('delete-shops-list-screen');
                    renderDeleteShopsList();
                });
                container.appendChild(card);
            });
        }

        function renderDeleteShopsList(searchQuery = '') {
            const container = document.getElementById('delete-shops-list-content');
            container.innerHTML = '';
            let filtered = shops.filter(s => s.regionId === deleteFlowRegionId);
            if (searchQuery) filtered = filtered.filter(s => s.name.toLowerCase().includes(searchQuery.toLowerCase()));

            if (filtered.length === 0) {
                container.innerHTML = `<div class="empty-state">${emptyIcon}لا توجد صيدليات للحذف.</div>`;
                return;
            }

            filtered.forEach(shop => {
                const isAr = isArabic(shop.name);
                const card = document.createElement('div');
                card.className = 'card';
                card.style.cursor = 'default';
                card.innerHTML = `
                    <div class="card-inner ${isAr ? '' : 'ltr-layout'}">
                        <div class="card-title ${isAr ? 'rtl-text' : 'ltr-text'}">${shop.name}</div>
                        <div class="card-action-btn" onclick="requestDelete('${shop.id}', 'shop')">
                            <svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        function requestDelete(id, type) {
            document.getElementById('delete-target-id').value = id;
            document.getElementById('delete-target-type').value = type;
            openModal('confirm-delete-modal');
        }

        function executeDelete() {
            const id = document.getElementById('delete-target-id').value;
            const type = document.getElementById('delete-target-type').value;

            if (type === 'region') {
                regions = regions.filter(r => r.id !== id);
                shops = shops.filter(s => s.regionId !== id); 
                saveData();
                renderDeleteRegions();
            } else if (type === 'shop') {
                shops = shops.filter(s => s.id !== id);
                saveData();
                renderDeleteShopsList();
            }

            closeModal('confirm-delete-modal');
        }

        // --- وظائف الإضافة والتعديل ---

        function addRegion() {
            const name = document.getElementById('new-region-name').value.trim();
            if (!name) return;
            regions.push({ id: generateId(), name: name });
            saveData();
            closeModal('add-region-modal');
            renderRegions();
        }

        function saveRegionEdit() {
            const id = document.getElementById('edit-region-id').value;
            const newName = document.getElementById('edit-region-name').value.trim();
            if (!newName) return;
            const regionIndex = regions.findIndex(r => r.id === id);
            if (regionIndex > -1) {
                regions[regionIndex].name = newName;
                saveData();
                closeModal('edit-region-modal');
                renderRegions();
            }
        }

        // --- منطق القائمة المنسدلة المخصصة ---
        function toggleCustomSelect() {
            const wrapper = document.getElementById('custom-region-wrapper');
            const dropdown = document.getElementById('custom-region-dropdown');
            
            if (!wrapper.classList.contains('disabled')) {
                wrapper.classList.toggle('active');
                dropdown.classList.toggle('show');
            }
        }

        function openAddShopModal(preselectedRegionId = null) {
            const dropdown = document.getElementById('custom-region-dropdown');
            const display = document.getElementById('custom-region-display');
            const hiddenInput = document.getElementById('shop-region-select');
            const wrapper = document.getElementById('custom-region-wrapper');

            // مسح وتجهيز
            dropdown.innerHTML = '';
            hiddenInput.value = '';
            display.textContent = 'اختر المنطقة';
            wrapper.classList.remove('disabled', 'active');
            dropdown.classList.remove('show');

            if(regions.length === 0) {
                display.textContent = 'لا توجد مناطق مضافة';
                wrapper.classList.add('disabled');
            }

            regions.forEach(r => {
                const opt = document.createElement('div');
                opt.className = 'custom-option';
                opt.textContent = r.name;
                opt.onclick = () => {
                    hiddenInput.value = r.id;
                    display.textContent = r.name;
                    dropdown.classList.remove('show');
                    wrapper.classList.remove('active');
                };
                dropdown.appendChild(opt);

                // إذا كنا داخل منطقة معينة ومفتوح من الأسفل
                if (preselectedRegionId && r.id === preselectedRegionId) {
                    hiddenInput.value = r.id;
                    display.textContent = r.name;
                }
            });

            if (preselectedRegionId) {
                wrapper.classList.add('disabled');
            }

            openModal('add-shop-modal');
        }

        function addShop() {
            const regionId = document.getElementById('shop-region-select').value;
            const name = document.getElementById('new-shop-name').value.trim();
            const link = document.getElementById('new-shop-link').value.trim();
            
            if (!regionId || !name) {
                return showCustomAlert("بيانات ناقصة", "يرجى اختيار المنطقة وكتابة اسم الصيدلية أولاً.", false);
            }

            shops.push({ id: generateId(), regionId: regionId, name: name, link: link, timestamp: new Date().toISOString() });
            saveData();
            closeModal('add-shop-modal');
            
            if (document.getElementById('region-screen').classList.contains('active')) renderShops();
            else if (document.getElementById('main-screen').classList.contains('active')) renderRegions();
        }

        function saveShopEdit() {
            const id = document.getElementById('edit-shop-id').value;
            const newName = document.getElementById('edit-shop-name').value.trim();
            const newLink = document.getElementById('edit-shop-link').value.trim();
            if (!newName) return;

            const shopIndex = shops.findIndex(s => s.id === id);
            if (shopIndex > -1) {
                shops[shopIndex].name = newName;
                shops[shopIndex].link = newLink;
                saveData();
                closeModal('edit-shop-modal');
                if (document.getElementById('region-screen').classList.contains('active')) renderShops();
            }
        }

        // --- استرداد بيانات CSV ---
        
        function triggerCSVUpload() {
            if (!currentRegionId) return showCustomAlert("خطأ", "الرجاء الدخول لمنطقة أولاً لاسترداد البيانات داخلها.", false);
            document.getElementById('csv-file-input').click();
        }

        document.getElementById('csv-file-input').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(event) {
                const text = event.target.result;
                const lines = text.split(/\r?\n/); 
                
                let addedCount = 0;
                
                for (let i = 0; i < lines.length; i++) {
                    const line = lines[i].trim();
                    if (!line || line.toUpperCase() === 'NAME,LINKMAP') continue; 

                    const parts = line.split(',');
                    if (parts.length >= 2) {
                        const name = parts[0].trim();
                        const link = parts.slice(1).join(',').trim();

                        if (name) {
                            shops.push({
                                id: generateId(),
                                regionId: currentRegionId,
                                name: name,
                                link: link,
                                timestamp: new Date().toISOString()
                            });
                            addedCount++;
                        }
                    }
                }

                if (addedCount > 0) {
                    saveData();
                    if (document.getElementById('region-screen').classList.contains('active')) renderShops();
                    showCustomAlert("اكتملت العملية", `تم استرداد وإضافة ${addedCount} صيدلية بنجاح.`, true);
                } else {
                    showCustomAlert("خطأ في الملف", "لم يتم العثور على بيانات صالحة. يرجى التأكد من أن الملف بصيغة: الاسم,الرابط", false);
                }
                
                e.target.value = '';
            };
            
            reader.readAsText(file);
        });

        // الإطلاق الأولي
        window.onload = () => { renderRegions(); };

        // --- الإضافات لحل مشكلة النقر المزدوج وتداخل الشاشات (دون حذف أي شيء) ---
        let _isTransitioning = false;
        const _originalSwitch = switchScreen;
        
        switchScreen = function(screenId) {
            _isTransitioning = true;
            _originalSwitch(screenId); // استدعاء الدالة الأصلية بشكل طبيعي
            
            // حظر النقرات الوهمية لمدة 400 ملي ثانية بعد الانتقال
            setTimeout(() => {
                _isTransitioning = false;
            }, 400); 
        };

        const preventGhostClicks = (e) => {
            if (_isTransitioning) {
                e.stopPropagation(); // إيقاف الحدث ومنعه من اختراق الشاشة
                e.preventDefault();
            }
        };

        // التقاط واعتراض أحداث الماوس الوهمية التي يولدها الهاتف بعد اللمس
        document.addEventListener('mousedown', preventGhostClicks, true);
        document.addEventListener('mouseup', preventGhostClicks, true);
        document.addEventListener('click', preventGhostClicks, true);
        document.addEventListener('touchend', preventGhostClicks, true);

    </script>
</body>
